{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": false,
    "tabWidth": 4,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "none",
    "arrowParens": "always",
    "overrides": [
        {
            "files": "*.vue",
            "options": {
                "printWidth": 90
            }
        }
    ]
}
